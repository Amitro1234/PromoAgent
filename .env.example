# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://ai-search-keshet.search.windows.net
AZURE_SEARCH_KEY=<your-admin-api-key>
AZURE_SEARCH_INDEX_NAME=tv-promos

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=aistoragekeshet;AccountKey=<your-key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=promo-docs-poc
EXCEL_BLOB_NAME=מעקבי פרומו.xlsx

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://azureopenaipilot.openai.azure.com/
AZURE_OPENAI_KEY=<your-api-key>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure OpenAI — Chat (separate deployment)
AZURE_OPENAI_CHAT_ENDPOINT=https://<your-resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_CHAT_KEY=<your-chat-api-key>
AZURE_OPENAI_CHAT_DEPLOYMENT=<deployment-name>

# API server
API_HOST=0.0.0.0
API_PORT=8000

# CORS — comma-separated allowed origins.
# Use * for local development only.
# For SharePoint: set to your tenant domain(s), e.g.
#   CORS_ORIGINS=https://yourtenant.sharepoint.com,https://yourtenant-admin.sharepoint.com
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Chat provider selection
# ---------------------------------------------------------------------------
# azure_openai  (default) — uses openai SDK + API key (current path)
# foundry       — uses Microsoft Agent Framework + Azure credential
CHAT_PROVIDER=azure_openai

# Azure credential type used by the Foundry provider
# cli               → AzureCliCredential (requires: az login)
# managed_identity  → ManagedIdentityCredential (Azure-hosted deployments)
AZURE_CREDENTIAL_TYPE=cli

# Microsoft Foundry — required when CHAT_PROVIDER=foundry
# Agent Framework canonical env var names (also accepted as FOUNDRY_* aliases below)
AZURE_AI_PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=<deployment-name>
# FOUNDRY_PROJECT_ENDPOINT=     (alias for AZURE_AI_PROJECT_ENDPOINT)
# FOUNDRY_MODEL_DEPLOYMENT_NAME=(alias for AZURE_AI_MODEL_DEPLOYMENT_NAME)